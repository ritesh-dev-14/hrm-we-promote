model Notification {
  id String @id @default(uuid())

  userId String
  user   User   @relation(fields: [userId], references: [id])

  title   String
  message String

  type NotificationType

  level NotificationLevel?

  isRead Boolean @default(false)

  readAt DateTime?

  entityId String?

  createdAt DateTime @default(now())

  @@index([userId])
  @@index([isRead])
}

enum NotificationLevel {
  INFO
  WARNING
  ESCALATION
  CRITICAL
}

enum NotificationType {
  // TASK_REMINDER
  // ESCALATION

  TASK_ASSIGNED
  TASK_REMINDER
  TASK_SUBMITTED
  TASK_OVERDUE

  MANAGER_REMINDER
  HR_ESCALATION
  ADMIN_ESCALATION

  GENERAL
}

model Leave {
  id String @id @default(uuid())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  startDate DateTime
  endDate   DateTime

  type LeaveType // 🔥 NEW
  days Int // 🔥 NEW (important)

  reason String

  status LeaveStatus @default(PENDING)

  reviewedBy String?
  reviewer   User?   @relation("LeaveReviewer", fields: [reviewedBy], references: [id], onDelete: SetNull)

  reviewNote String?

  createdAt DateTime @default(now())

  @@index([userId])
  @@index([status])
}

model LeaveBalance {
  id String @id @default(uuid())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  casual Int @default(14)
  sick   Int @default(6)

  usedCasual Int @default(0)
  usedSick   Int @default(0)

  year Int

  createdAt DateTime @default(now())

  @@unique([userId, year]) // 🔥 IMPORTANT FIX
}

enum LeaveStatus {
  PENDING
  APPROVED
  REJECTED
}

enum LeaveType {
  CASUAL
  SICK
}

model TaskGroup {
  id String @id @default(uuid())

  name String

  managerId String
  manager   User   @relation(fields: [managerId], references: [id])

  createdAt DateTime @default(now())

  members TaskGroupMember[]
}

model TaskGroupMember {
  id String @id @default(uuid())

  groupId String
  userId  String

  group TaskGroup @relation(fields: [groupId], references: [id])

  user User @relation(fields: [userId], references: [id])

  createdAt DateTime @default(now())

  @@unique([groupId, userId])
}

model TaskEscalation {
  id String @id @default(uuid())

  managerId String
  manager   User   @relation(fields: [managerId], references: [id])

  date DateTime

  level1Sent Boolean @default(false) // 1 PM
  level2Sent Boolean @default(false) // 2 PM
  level3Sent Boolean @default(false) // 2:30 PM HR
  level4Sent Boolean @default(false) // 4 PM ADMIN

  createdAt DateTime @default(now())

  @@unique([managerId, date])
}

model TaskItem {
  id String @id @default(uuid())

  taskId String
  task   Task   @relation(fields: [taskId], references: [id], onDelete: Cascade)

  title String

  description String?

  theme String?

  referenceLink String?

  instructions String?

  order Int?

  status TaskItemStatus @default(PENDING)

  assignments TaskItemAssignment[]

  createdAt DateTime @default(now())

  @@index([taskId])
}

enum TaskItemStatus {
  PENDING
  ASSIGNED
  IN_PROGRESS
  SUBMITTED
  VERIFIED
}

model TaskItemAssignment {
  id String @id @default(uuid())

  taskItemId String
  userId     String

  taskItem TaskItem @relation(fields: [taskItemId], references: [id], onDelete: Cascade)

  employee User @relation(fields: [userId], references: [id])

  status AssignmentStatus @default(ASSIGNED)

  submittedAt DateTime?

  submission TaskItemSubmission?

  createdAt DateTime @default(now())

  @@unique([taskItemId, userId])
  @@index([userId])
}

model TaskItemSubmission {
  id String @id @default(uuid())

  assignmentId String @unique

  driveLink String

  remarks String?

  submittedAt DateTime @default(now())

  verifiedByManager Boolean @default(false)

  assignment TaskItemAssignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
}
