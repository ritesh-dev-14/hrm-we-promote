generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                      String                    @id @default(uuid())
  employeeId              String                    @unique
  name                    String
  email                   String                    @unique
  password                String
  role                    Role
  position                String?
  managerId               String?
  createdById             String?
  createdAt               DateTime                  @default(now())
  departmentId            String?
  attendances             Attendance[]
  employeeCoverages       EmployeeTaskCoverage[]    @relation("EmployeeCoverage")
  managerCoverages        EmployeeTaskCoverage[]    @relation("ManagerCoverage")
  reviewedLeaves          Leave[]                   @relation("LeaveReviewer")
  leaves                  Leave[]
  leaveBalance            LeaveBalance[]
  notifications           Notification[]
  createdTasks            Task[]                    @relation("CreatedTasks")
  assignments             TaskAssignment[]
  employeeEscalations     TaskEscalation[]          @relation("EmployeeEscalation")
  managerEscalations      TaskEscalation[]          @relation("ManagerEscalation")
  taskItemAssignments     TaskItemAssignment[]
  coordinatorAssignments  CoordinatorAssignment[]   @relation("CreatedCoordinatorAssignments")
  assignedCoordinatorTasks CoordinatorAssignment[]  @relation("AssignedToUser")
  createdBy               User?                     @relation("Hierarchy", fields: [createdById], references: [id])
  children                User[]                    @relation("Hierarchy")
  department              Department?               @relation(fields: [departmentId], references: [id])
  manager                 User?                     @relation("UserManager", fields: [managerId], references: [id])
  subordinates            User[]                    @relation("UserManager")
}

model Attendance {
  id         String           @id @default(uuid())
  userId     String
  date       DateTime
  startTime  DateTime?
  endTime    DateTime?
  totalHours Float?
  breakHours Float?
  status     AttendanceStatus
  createdAt  DateTime         @default(now())
  user       User             @relation(fields: [userId], references: [id])
  breaks     Break[]

  @@unique([userId, date])
}

model Break {
  id           String     @id @default(uuid())
  attendanceId String
  startTime    DateTime
  endTime      DateTime?
  createdAt    DateTime   @default(now())
  attendance   Attendance @relation(fields: [attendanceId], references: [id])
}

model Task {
  id          String           @id @default(uuid())
  description String?
  status      TaskStatus       @default(DRAFT)
  createdAt   DateTime         @default(now())
  createdById String
  progress    Int              @default(0)
  endDate     DateTime
  projectName String
  startDate   DateTime
  createdBy   User             @relation("CreatedTasks", fields: [createdById], references: [id])
  assignments TaskAssignment[]
  coordinatorAssignments CoordinatorAssignment[] @relation("CoordinatorAssignments")
  items       TaskItem[]

  @@index([createdById])
  @@index([startDate])
  @@index([endDate])
}

model TaskAssignment {
  id              String           @id @default(uuid())
  taskId          String
  userId          String
  status          AssignmentStatus @default(ASSIGNED)
  createdAt       DateTime         @default(now())
  reminderSent    Boolean          @default(false)
  submittedAt     DateTime?
  acceptedAt      DateTime?
  completedAt     DateTime?
  progress        Int              @default(0)
  rejectedAt      DateTime?
  rejectionReason String?
  startedAt       DateTime?
  verifiedAt      DateTime?
  workDate        DateTime
  task            Task             @relation(fields: [taskId], references: [id])
  employee        User             @relation(fields: [userId], references: [id])
  submission      TaskSubmission?

  @@unique([taskId, userId])
  @@index([workDate])
  @@index([userId, workDate])
  @@index([userId])
  @@index([status])
}

model TaskSubmission {
  id                String         @id @default(uuid())
  assignmentId      String         @unique
  completedCount    Int
  pendingCount      Int
  driveLink         String
  submittedAt       DateTime       @default(now())
  remarks           String?
  verifiedByManager Boolean        @default(false)
  assignment        TaskAssignment @relation(fields: [assignmentId], references: [id])
}

model Notification {
  id        String             @id @default(uuid())
  userId    String
  message   String
  type      NotificationType
  isRead    Boolean            @default(false)
  createdAt DateTime           @default(now())
  entityId  String?
  level     NotificationLevel?
  readAt    DateTime?
  title     String
  user      User               @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([isRead])
}

model Leave {
  id         String      @id @default(uuid())
  userId     String
  startDate  DateTime
  endDate    DateTime
  reason     String
  status     LeaveStatus @default(PENDING)
  reviewedBy String?
  reviewNote String?
  createdAt  DateTime    @default(now())
  days       Int
  type       LeaveType
  reviewer   User?       @relation("LeaveReviewer", fields: [reviewedBy], references: [id])
  user       User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
}

model LeaveBalance {
  id         String   @id @default(uuid())
  userId     String
  casual     Int      @default(14)
  sick       Int      @default(6)
  usedCasual Int      @default(0)
  usedSick   Int      @default(0)
  year       Int
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, year])
}

model TaskEscalation {
  id               String           @id @default(uuid())
  managerId        String
  escalationDate   DateTime         @map("date")
  createdAt        DateTime         @default(now())
  adminEscalatedAt DateTime?
  adminMailSent    Boolean          @default(false)
  employeeId       String
  finalEscalatedAt DateTime?
  hrEscalatedAt    DateTime?
  hrMailSent       Boolean          @default(false)
  managerMailSent  Boolean          @default(false)
  popupSent        Boolean          @default(false)
  reminder1SentAt  DateTime?
  reminder2SentAt  DateTime?
  reminder3SentAt  DateTime?
  resolvedAt       DateTime?
  status           EscalationStatus @default(PENDING)
  type             EscalationType   @default(NEXT_DAY_MISSING)
  employee         User             @relation("EmployeeEscalation", fields: [employeeId], references: [id])
  manager          User             @relation("ManagerEscalation", fields: [managerId], references: [id])

  @@unique([employeeId, escalationDate, type])
  @@index([managerId])
  @@index([status])
  @@index([escalationDate])
}

model TaskItem {
  id          String               @id @default(uuid())
  taskId      String
  title       String
  description String?
  order       Int?
  status      TaskItemStatus       @default(DRAFT)
  createdAt   DateTime             @default(now())
  progress    Int                  @default(0)
  dueDate     DateTime
  priority    Priority             @default(MEDIUM)
  task        Task                 @relation(fields: [taskId], references: [id], onDelete: Cascade)
  assignments TaskItemAssignment[]

  @@index([taskId])
}

model TaskItemSubmission {
  id                String             @id @default(uuid())
  assignmentId      String             @unique
  driveLink         String?
  remarks           String?
  submittedAt       DateTime           @default(now())
  verifiedByManager Boolean            @default(false)
  unableToSubmitReason String?
  assignment        TaskItemAssignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
}

model TaskItemAssignment {
  id              String              @id @default(uuid())
  taskItemId      String
  userId          String
  status          AssignmentStatus    @default(ASSIGNED)
  submittedAt     DateTime?
  createdAt       DateTime            @default(now())
  acceptedAt      DateTime?
  completedAt     DateTime?
  progress        Int                 @default(0)
  rejectedAt      DateTime?
  rejectionReason String?
  startedAt       DateTime?
  verifiedAt      DateTime?
  taskItem        TaskItem            @relation(fields: [taskItemId], references: [id], onDelete: Cascade)
  employee        User                @relation(fields: [userId], references: [id])
  submission      TaskItemSubmission?

  @@unique([taskItemId, userId])
  @@index([userId])
}

model Department {
  id        String   @id @default(uuid())
  name      String   @unique
  createdAt DateTime @default(now())
  users     User[]
}

model EmployeeTaskCoverage {
  id         String    @id @default(uuid())
  employeeId String
  managerId  String
  date       DateTime
  taskCount  Int       @default(0)
  checkedAt  DateTime?
  createdAt  DateTime  @default(now())
  employee   User      @relation("EmployeeCoverage", fields: [employeeId], references: [id])
  manager    User      @relation("ManagerCoverage", fields: [managerId], references: [id])

  @@unique([employeeId, date])
  @@index([managerId])
  @@index([date])
}

model CoordinatorAssignment {
  id               String           @id @default(uuid())
  taskId           String
  assignedToId     String
  createdById      String
  assignedBy       String           // Text field - coordinator's name entered manually
  assignedTime     DateTime         @default(now())
  completionDate   DateTime
  reason           String?          // Only for incomplete tasks
  employeeNumber   String
  employeeEmail    String
  status           AssignmentStatus @default(ASSIGNED)
  submittedAt      DateTime?
  completedAt      DateTime?
  rejectedAt       DateTime?
  rejectionReason  String?
  startedAt        DateTime?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  
  task             Task             @relation("CoordinatorAssignments", fields: [taskId], references: [id], onDelete: Cascade)
  assignedTo       User             @relation("AssignedToUser", fields: [assignedToId], references: [id])
  createdBy        User             @relation("CreatedCoordinatorAssignments", fields: [createdById], references: [id])

  @@unique([taskId, assignedToId])
  @@index([createdById])
  @@index([assignedToId])
  @@index([status])
  @@index([assignedTime])
}

enum EscalationStatus {
  PENDING
  MANAGER_NOTIFIED
  HR_ESCALATED
  ADMIN_ESCALATED
  FINAL_ESCALATED
  RESOLVED
}

enum Role {
  ADMIN
  HR
  MANAGER
  EMPLOYEE
  COORDINATOR
}

enum AttendanceStatus {
  PRESENT
  HALF_DAY
  ABSENT
  HOLIDAY
  LEAVE
}

enum SetupType {
  PREMIUM
  VERY_PREMIUM
  PHONE
}

enum TaskStatus {
  DRAFT
  ASSIGNED
  IN_PROGRESS
  SUBMITTED
  VERIFIED
  REJECTED
  COMPLETED
  OVERDUE
  CANCELLED
}

enum AssignmentStatus {
  ASSIGNED
  IN_PROGRESS
  SUBMITTED
  VERIFIED
  REJECTED
  COMPLETED
  PENDING
  UNABLE_TO_SUBMIT
}

enum NotificationLevel {
  INFO
  WARNING
  ESCALATION
  CRITICAL
}

enum NotificationType {
  TASK_ASSIGNED
  TASK_REMINDER
  TASK_SUBMITTED
  TASK_OVERDUE
  MANAGER_REMINDER
  HR_ESCALATION
  ADMIN_ESCALATION
  GENERAL
}

enum LeaveStatus {
  PENDING
  APPROVED
  REJECTED
}

enum LeaveType {
  CASUAL
  SICK
}

enum TaskItemStatus {
  DRAFT
  ASSIGNED
  IN_PROGRESS
  SUBMITTED
  VERIFIED
  REJECTED
  COMPLETED
  PENDING
  UNABLE_TO_SUBMIT
}

enum Priority {
  LOW
  MEDIUM
  HIGH
}

enum EscalationType {
  NEXT_DAY_MISSING
  FUTURE_4_DAYS_MISSING
}
