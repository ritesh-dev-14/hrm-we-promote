model TaskEscalation {
  id String @id @default(uuid())

  employeeId String

  managerId String

  type EscalationType @default(NEXT_DAY_MISSING)

  status EscalationStatus @default(PENDING)

  //
  // 🔥 MANAGER REMINDERS
  //
  reminder1SentAt DateTime?
  reminder2SentAt DateTime?
  reminder3SentAt DateTime?

  //
  // 🔥 HR ESCALATION
  //
  hrEscalatedAt DateTime?

  //
  // 🔥 ADMIN ESCALATION
  //
  adminEscalatedAt DateTime?

  //
  // 🔥 FINAL ESCALATION
  //
  finalEscalatedAt DateTime?

  //
  // 🔥 RESOLVED
  //
  resolvedAt DateTime?

  //
  // 🔥 MAIL TRACKING
  //
  managerMailSent Boolean @default(false)

  hrMailSent Boolean @default(false)

  adminMailSent Boolean @default(false)

  //
  // 🔥 POPUP TRACKING
  //
  popupSent Boolean @default(false)

  createdAt DateTime @default(now())

  employee User @relation("EmployeeEscalation", fields: [employeeId], references: [id])

  manager User    @relation("ManagerEscalation", fields: [managerId], references: [id])
  
  // NOTE: `userId` relation removed (was accidental) to match DB schema.

  // Map `escalationDate` to the existing DB column `date`
  escalationDate DateTime @map("date")

  @@unique([employeeId, escalationDate, type])
  @@index([managerId])
  @@index([status])
  @@index([escalationDate])
}

enum EscalationStatus {
  PENDING
  MANAGER_NOTIFIED
  HR_ESCALATED
  ADMIN_ESCALATED
  FINAL_ESCALATED
  RESOLVED
}

model TaskItem {
  id            String               @id @default(uuid())
  taskId        String
  title         String
  description   String?
  dueDate       DateTime
  priority      Priority             @default(MEDIUM)
  order         Int?
  status        TaskItemStatus       @default(DRAFT)
  createdAt     DateTime             @default(now())
  task          Task                 @relation(fields: [taskId], references: [id], onDelete: Cascade)
  assignments   TaskItemAssignment[]

  progress Int @default(0)

  @@index([taskId])
}

model TaskItemSubmission {
  id                String             @id @default(uuid())
  assignmentId      String             @unique
  driveLink         String
  remarks           String?
  submittedAt       DateTime           @default(now())
  verifiedByManager Boolean            @default(false)
  assignment        TaskItemAssignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
}

enum Role {
  ADMIN
  HR
  MANAGER
  EMPLOYEE
}

enum AttendanceStatus {
  PRESENT
  HALF_DAY
  ABSENT
  HOLIDAY
  LEAVE
}

enum SetupType {
  PREMIUM
  VERY_PREMIUM
  PHONE
}

enum TaskStatus {
  DRAFT
  ASSIGNED
  IN_PROGRESS
  SUBMITTED
  VERIFIED
  REJECTED
  COMPLETED
  OVERDUE
  CANCELLED
}

enum AssignmentStatus {
  PENDING
  ASSIGNED
  IN_PROGRESS
  SUBMITTED
  VERIFIED
  REJECTED
  COMPLETED
}

enum NotificationLevel {
  INFO
  WARNING
  ESCALATION
  CRITICAL
}

enum NotificationType {
  TASK_ASSIGNED
  TASK_REMINDER
  TASK_SUBMITTED
  TASK_OVERDUE
  MANAGER_REMINDER
  HR_ESCALATION
  ADMIN_ESCALATION
  GENERAL
}

enum LeaveStatus {
  PENDING
  APPROVED
  REJECTED
}

enum LeaveType {
  CASUAL
  SICK
}

enum TaskItemStatus {
  PENDING
  DRAFT
  ASSIGNED
  IN_PROGRESS
  SUBMITTED
  VERIFIED
  REJECTED
  COMPLETED
}

enum Priority {
  LOW
  MEDIUM
  HIGH
}

model TaskItemAssignment {
  id String @id @default(uuid())

  taskItemId String
  userId     String

  status AssignmentStatus @default(ASSIGNED)

  progress Int @default(0)

  acceptedAt DateTime?

  startedAt DateTime?

  submittedAt DateTime?

  verifiedAt DateTime?

  completedAt DateTime?

  rejectedAt DateTime?

  rejectionReason String?

  createdAt DateTime @default(now())

  taskItem TaskItem @relation(fields: [taskItemId], references: [id], onDelete: Cascade)

  employee User @relation(fields: [userId], references: [id])

  submission TaskItemSubmission?

  @@unique([taskItemId, userId])
  @@index([userId])
}

model Department {
  id        String   @id @default(uuid())
  name      String   @unique
  createdAt DateTime @default(now())

  // 🔥 ADD THIS
  users User[]
}

model EmployeeTaskCoverage {
  id String @id @default(uuid())

  employeeId String
  managerId  String

  date DateTime

  // hasTask Boolean @default(false)
  taskCount Int @default(0)

  checkedAt DateTime?

  createdAt DateTime @default(now())

  employee User @relation("EmployeeCoverage", fields: [employeeId], references: [id])

  manager User @relation("ManagerCoverage", fields: [managerId], references: [id])

  @@unique([employeeId, date])
  @@index([managerId])
  @@index([date])
}

enum EscalationType {
  NEXT_DAY_MISSING
  FUTURE_4_DAYS_MISSING
}
