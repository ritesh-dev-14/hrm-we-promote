model User {
  id          String   @id @default(uuid())
  employeeId  String   @unique

  name        String
  email       String   @unique
  password    String
  role        Role

  department  String?
  position    String?     // ✅ NEW FIELD

  managerId   String?     // ✅ NEW FIELD

  // 🔥 SELF RELATION (manager ↔ employees)
  manager     User?  @relation("UserManager", fields: [managerId], references: [id])
  subordinates User[] @relation("UserManager")

  createdById String?
  createdBy   User?  @relation("Hierarchy", fields: [createdById], references: [id])
  children    User[] @relation("Hierarchy")

  attendances Attendance[]

  tasksCreated Task[] @relation("ManagerTasks")
  assignments  TaskAssignment[]
  notifications Notification[]

  createdAt   DateTime @default(now())
}

enum Role {
  ADMIN
  HR
  MANAGER
  EMPLOYEE
}

model Attendance {
  id         String   @id @default(uuid())
  userId     String
  date       DateTime

  startTime  DateTime?
  endTime    DateTime?

  totalHours Float?      // 👈 already exists (final working hours)
  breakHours Float?      // 👈 NEW (total break time)

  status     AttendanceStatus

  user User @relation(fields: [userId], references: [id])

  breaks Break[]         // 👈 NEW RELATION

  createdAt DateTime @default(now())

  @@unique([userId, date])
}

model Break {
  id            String   @id @default(uuid())
  attendanceId  String

  startTime     DateTime
  endTime       DateTime?

  attendance Attendance @relation(fields: [attendanceId], references: [id])

  createdAt DateTime @default(now())
}

enum AttendanceStatus {
  PRESENT
  HALF_DAY
  ABSENT
   HOLIDAY
}


//Task Management Models

model Task {
  id          String   @id @default(uuid())

  title       String
  description String?

  date        DateTime   // 👈 IMPORTANT (schedule date)

  location    String?    // Google map link or manual
  setupType   SetupType  // 👈 ENUM

  managerId   String
  // manager     User @relation(fields: [managerId], references: [id])
  manager     User @relation("ManagerTasks", fields: [managerId], references: [id])

  status      TaskStatus @default(PENDING)

  assignments TaskAssignment[]

  createdAt   DateTime @default(now())
}

enum SetupType {
  PREMIUM
  VERY_PREMIUM
  PHONE
}

enum TaskStatus {
  PENDING
  ASSIGNED
  SUBMITTED
  VERIFIED
}



