generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                  String               @id @default(uuid())
  employeeId          String               @unique
  name                String
  email               String               @unique
  password            String
  role                Role
  department          String?
  position            String?
  managerId           String?
  createdById         String?
  createdAt           DateTime             @default(now())
  attendances         Attendance[]
  reviewedLeaves      Leave[]              @relation("LeaveReviewer")
  leaves              Leave[]
  leaveBalance        LeaveBalance[]
  notifications       Notification[]
  createdTasks        Task[]               @relation("CreatedTasks")
  assignments         TaskAssignment[]
  taskEscalations     TaskEscalation[]
  managedGroups       TaskGroup[]
  groupMemberships    TaskGroupMember[]
  taskItemAssignments TaskItemAssignment[]
  createdBy           User?                @relation("Hierarchy", fields: [createdById], references: [id])
  children            User[]               @relation("Hierarchy")
  manager             User?                @relation("UserManager", fields: [managerId], references: [id])
  subordinates        User[]               @relation("UserManager")
}

model Attendance {
  id         String           @id @default(uuid())
  userId     String
  date       DateTime
  startTime  DateTime?
  endTime    DateTime?
  totalHours Float?
  breakHours Float?
  status     AttendanceStatus
  createdAt  DateTime         @default(now())
  user       User             @relation(fields: [userId], references: [id])
  breaks     Break[]

  @@unique([userId, date])
}

model Break {
  id           String     @id @default(uuid())
  attendanceId String
  startTime    DateTime
  endTime      DateTime?
  createdAt    DateTime   @default(now())
  attendance   Attendance @relation(fields: [attendanceId], references: [id])
}

model Task {
  id            String           @id @default(uuid())
  title         String
  description   String?
  date          DateTime
  location      String?
  setupType     SetupType
  status        TaskStatus       @default(DRAFT)
  createdAt     DateTime         @default(now())
  createdById   String
  instructions  String?
  isGroupTask   Boolean          @default(false)
  referenceLink String?
  createdBy     User             @relation("CreatedTasks", fields: [createdById], references: [id])
  assignments   TaskAssignment[]
  items         TaskItem[]

  @@index([createdById])
  @@index([date])
}

model TaskAssignment {
  id           String           @id @default(uuid())
  taskId       String
  userId       String
  status       AssignmentStatus @default(ASSIGNED)
  createdAt    DateTime         @default(now())
  reminderSent Boolean          @default(false)
  submittedAt  DateTime?
  taskGroupId  String?
  taskGroup    TaskGroup?       @relation(fields: [taskGroupId], references: [id])
  task         Task             @relation(fields: [taskId], references: [id])
  employee     User             @relation(fields: [userId], references: [id])
  submission   TaskSubmission?

  @@unique([taskId, userId])
  @@index([userId])
  @@index([taskGroupId])
  @@index([status])
}

model TaskSubmission {
  id                String         @id @default(uuid())
  assignmentId      String         @unique
  completedCount    Int
  pendingCount      Int
  driveLink         String
  submittedAt       DateTime       @default(now())
  remarks           String?
  verifiedByManager Boolean        @default(false)
  assignment        TaskAssignment @relation(fields: [assignmentId], references: [id])
}

model Notification {
  id        String             @id @default(uuid())
  userId    String
  message   String
  type      NotificationType
  isRead    Boolean            @default(false)
  createdAt DateTime           @default(now())
  entityId  String?
  level     NotificationLevel?
  readAt    DateTime?
  title     String
  user      User               @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([isRead])
}

model Leave {
  id         String      @id @default(uuid())
  userId     String
  startDate  DateTime
  endDate    DateTime
  reason     String
  status     LeaveStatus @default(PENDING)
  reviewedBy String?
  reviewNote String?
  createdAt  DateTime    @default(now())
  days       Int
  type       LeaveType
  reviewer   User?       @relation("LeaveReviewer", fields: [reviewedBy], references: [id])
  user       User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
}

model LeaveBalance {
  id         String   @id @default(uuid())
  userId     String
  casual     Int      @default(14)
  sick       Int      @default(6)
  usedCasual Int      @default(0)
  usedSick   Int      @default(0)
  year       Int
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, year])
}

model TaskGroup {
  id                  String               @id @default(uuid())
  name                String
  managerId           String
  createdAt           DateTime             @default(now())
  taskAssignments     TaskAssignment[]
  manager             User                 @relation(fields: [managerId], references: [id])
  members             TaskGroupMember[]
  taskItemAssignments TaskItemAssignment[]
}

model TaskGroupMember {
  id        String    @id @default(uuid())
  groupId   String
  userId    String
  createdAt DateTime  @default(now())
  group     TaskGroup @relation(fields: [groupId], references: [id])
  user      User      @relation(fields: [userId], references: [id])

  @@unique([groupId, userId])
}

model TaskEscalation {
  id         String   @id @default(uuid())
  managerId  String
  date       DateTime
  level1Sent Boolean  @default(false)
  level2Sent Boolean  @default(false)
  level3Sent Boolean  @default(false)
  level4Sent Boolean  @default(false)
  createdAt  DateTime @default(now())
  manager    User     @relation(fields: [managerId], references: [id])

  @@unique([managerId, date])
}

model TaskItem {
  id            String               @id @default(uuid())
  taskId        String
  title         String
  description   String?
  theme         String?
  referenceLink String?
  instructions  String?
  order         Int?
  status        TaskItemStatus       @default(PENDING)
  createdAt     DateTime             @default(now())
  task          Task                 @relation(fields: [taskId], references: [id], onDelete: Cascade)
  assignments   TaskItemAssignment[]

  @@index([taskId])
}

model TaskItemAssignment {
  id          String              @id @default(uuid())
  taskItemId  String
  userId      String
  status      AssignmentStatus    @default(ASSIGNED)
  submittedAt DateTime?
  createdAt   DateTime            @default(now())
  taskGroupId String?
  taskGroup   TaskGroup?          @relation(fields: [taskGroupId], references: [id])
  taskItem    TaskItem            @relation(fields: [taskItemId], references: [id], onDelete: Cascade)
  employee    User                @relation(fields: [userId], references: [id])
  submission  TaskItemSubmission?

  @@unique([taskItemId, userId])
  @@index([userId])
  @@index([taskGroupId])
}

model TaskItemSubmission {
  id                String             @id @default(uuid())
  assignmentId      String             @unique
  driveLink         String
  remarks           String?
  submittedAt       DateTime           @default(now())
  verifiedByManager Boolean            @default(false)
  assignment        TaskItemAssignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
}

enum Role {
  ADMIN
  HR
  MANAGER
  EMPLOYEE
}

enum AttendanceStatus {
  PRESENT
  HALF_DAY
  ABSENT
  HOLIDAY
  LEAVE
}

enum SetupType {
  PREMIUM
  VERY_PREMIUM
  PHONE
}

enum TaskStatus {
  DRAFT
  ASSIGNED
  IN_PROGRESS
  SUBMITTED
  VERIFIED
  OVERDUE
  CANCELLED
}

enum AssignmentStatus {
  ASSIGNED
  SUBMITTED
  APPROVED
}

enum NotificationLevel {
  INFO
  WARNING
  ESCALATION
  CRITICAL
}

enum NotificationType {
  TASK_ASSIGNED
  TASK_REMINDER
  TASK_SUBMITTED
  TASK_OVERDUE
  MANAGER_REMINDER
  HR_ESCALATION
  ADMIN_ESCALATION
  GENERAL
}

enum LeaveStatus {
  PENDING
  APPROVED
  REJECTED
}

enum LeaveType {
  CASUAL
  SICK
}

enum TaskItemStatus {
  PENDING
  ASSIGNED
  IN_PROGRESS
  SUBMITTED
  VERIFIED
}
