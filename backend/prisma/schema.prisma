generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                      String                    @id @default(uuid())
  employeeId              String                    @unique
  name                    String
  email                   String                    @unique
  password                String
  role                    Role
  position                String?
  managerId               String?
  createdById             String?
  createdAt               DateTime                  @default(now())
  departmentId            String?
  attendances             Attendance[]
  employeeCoverages       EmployeeTaskCoverage[]    @relation("EmployeeCoverage")
  managerCoverages        EmployeeTaskCoverage[]    @relation("ManagerCoverage")
  reviewedLeaves          Leave[]                   @relation("LeaveReviewer")
  leaves                  Leave[]
  leaveBalance            LeaveBalance[]
  notifications           Notification[]
  createdTasks            Task[]                    @relation("CreatedTasks")
  projectAssignments      ProjectAssignment[]       @relation("ProjectAssignmentManager")
  createdProjects              Project[]                 @relation("CreatedProjects")
  createdProjectMonthlySheets  ProjectMonthlySheet[]     @relation("CreatedProjectMonthlySheets")
  createdShootWorkspaces       ShootWorkspace[]          @relation("UserCreatedShootWorkspaces")
  createdShootTasks            ShootTask[]               @relation("UserCreatedShootTasks")
  submittedShootSubTasks       ShootSubTask[]            @relation("UserSubmittedShootSubTasks")
  reviewedShootSubTasks        ShootSubTask[]            @relation("UserReviewedShootSubTasks")
  shootWorkspaceMemberships    ShootWorkspaceMember[]    @relation("UserShootWorkspaceMembers")
  sentFollowUps                CoordinatorFollowUp[]
  assignments                  TaskAssignment[]
  employeeEscalations     TaskEscalation[]          @relation("EmployeeEscalation")
  managerEscalations      TaskEscalation[]          @relation("ManagerEscalation")
  taskItemAssignments     TaskItemAssignment[]
  coordinatorAssignments  CoordinatorAssignment[]   @relation("CreatedCoordinatorAssignments")
  assignedCoordinatorTasks CoordinatorAssignment[]  @relation("AssignedToUser")
  createdBy               User?                     @relation("Hierarchy", fields: [createdById], references: [id])
  children                User[]                    @relation("Hierarchy")
  department              Department?               @relation(fields: [departmentId], references: [id])
  manager                 User?                     @relation("UserManager", fields: [managerId], references: [id])
  subordinates            User[]                    @relation("UserManager")
  userDepartments         UserDepartment[]          @relation("UserDepartments")
  employeeManagers        UserManager[]             @relation("EmployeeManagers")
  managerEmployees        UserManager[]             @relation("ManagerEmployees")
  sidebarUnreads          SidebarUnread[]
}

model Attendance {
  id         String           @id @default(uuid())
  userId     String
  date       DateTime
  startTime  DateTime?
  endTime    DateTime?
  totalHours Float?
  breakHours Float?
  status     AttendanceStatus
  createdAt  DateTime         @default(now())
  user       User             @relation(fields: [userId], references: [id])
  breaks     Break[]

  @@unique([userId, date])
}

model Break {
  id           String     @id @default(uuid())
  attendanceId String
  startTime    DateTime
  endTime      DateTime?
  createdAt    DateTime   @default(now())
  attendance   Attendance @relation(fields: [attendanceId], references: [id])
}

model Task {
  id          String           @id @default(uuid())
  description String?
  status      TaskStatus       @default(DRAFT)
  createdAt   DateTime         @default(now())
  createdById String
  progress    Int              @default(0)
  endDate     DateTime
  projectName String
  startDate   DateTime
  createdBy   User             @relation("CreatedTasks", fields: [createdById], references: [id])
  assignments TaskAssignment[]
  coordinatorAssignments CoordinatorAssignment[] @relation("CoordinatorAssignments")
  items       TaskItem[]

  @@index([createdById])
  @@index([startDate])
  @@index([endDate])
}

model TaskAssignment {
  id              String           @id @default(uuid())
  taskId          String
  userId          String
  status          AssignmentStatus @default(ASSIGNED)
  createdAt       DateTime         @default(now())
  reminderSent    Boolean          @default(false)
  submittedAt     DateTime?
  acceptedAt      DateTime?
  completedAt     DateTime?
  progress        Int              @default(0)
  rejectedAt      DateTime?
  rejectionReason String?
  startedAt       DateTime?
  verifiedAt      DateTime?
  workDate        DateTime
  task            Task             @relation(fields: [taskId], references: [id])
  employee        User             @relation(fields: [userId], references: [id])
  submission      TaskSubmission?

  @@unique([taskId, userId])
  @@index([workDate])
  @@index([userId, workDate])
  @@index([userId])
  @@index([status])
}

model TaskSubmission {
  id                String         @id @default(uuid())
  assignmentId      String         @unique
  completedCount    Int
  pendingCount      Int
  driveLink         String
  submittedAt       DateTime       @default(now())
  remarks           String?
  verifiedByManager Boolean        @default(false)
  assignment        TaskAssignment @relation(fields: [assignmentId], references: [id])
}

model Notification {
  id        String             @id @default(uuid())
  userId    String
  message   String
  type      NotificationType
  isRead    Boolean            @default(false)
  createdAt DateTime           @default(now())
  entityId  String?
  level     NotificationLevel?
  readAt    DateTime?
  title     String
  user      User               @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([isRead])
}

model Leave {
  id         String      @id @default(uuid())
  userId     String
  startDate  DateTime
  endDate    DateTime
  reason     String
  status     LeaveStatus @default(PENDING)
  reviewedBy String?
  reviewNote String?
  createdAt  DateTime    @default(now())
  days       Int
  type       LeaveType
  reviewer   User?       @relation("LeaveReviewer", fields: [reviewedBy], references: [id])
  user       User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
}

model LeaveBalance {
  id         String   @id @default(uuid())
  userId     String
  casual     Int      @default(14)
  sick       Int      @default(6)
  usedCasual Int      @default(0)
  usedSick   Int      @default(0)
  year       Int
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, year])
}

model TaskEscalation {
  id               String           @id @default(uuid())
  managerId        String
  escalationDate   DateTime         @map("date")
  createdAt        DateTime         @default(now())
  adminEscalatedAt DateTime?
  adminMailSent    Boolean          @default(false)
  employeeId       String
  finalEscalatedAt DateTime?
  hrEscalatedAt    DateTime?
  hrMailSent       Boolean          @default(false)
  managerMailSent  Boolean          @default(false)
  popupSent        Boolean          @default(false)
  reminder1SentAt  DateTime?
  reminder2SentAt  DateTime?
  reminder3SentAt  DateTime?
  resolvedAt       DateTime?
  status           EscalationStatus @default(PENDING)
  type             EscalationType   @default(NEXT_DAY_MISSING)
  employee         User             @relation("EmployeeEscalation", fields: [employeeId], references: [id])
  manager          User             @relation("ManagerEscalation", fields: [managerId], references: [id])

  @@unique([employeeId, escalationDate, type])
  @@index([managerId])
  @@index([status])
  @@index([escalationDate])
}

model TaskItem {
  id          String               @id @default(uuid())
  taskId      String
  title       String
  description String?
  order       Int?
  status      TaskItemStatus       @default(DRAFT)
  createdAt   DateTime             @default(now())
  progress    Int                  @default(0)
  dueDate     DateTime
  priority    Priority             @default(MEDIUM)
  referenceLink String?
  rawDataLink   String?
  task        Task                 @relation(fields: [taskId], references: [id], onDelete: Cascade)
  assignments TaskItemAssignment[]

  @@index([taskId])
}

model TaskItemSubmission {
  id                String             @id @default(uuid())
  assignmentId      String             @unique
  driveLink         String?
  remarks           String?
  submittedAt       DateTime           @default(now())
  verifiedByManager Boolean            @default(false)
  unableToSubmitReason String?
  assignment        TaskItemAssignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
}

model TaskItemAssignment {
  id              String              @id @default(uuid())
  taskItemId      String
  userId          String
  status          AssignmentStatus    @default(ASSIGNED)
  submittedAt     DateTime?
  createdAt       DateTime            @default(now())
  acceptedAt      DateTime?
  completedAt     DateTime?
  progress        Int                 @default(0)
  rejectedAt      DateTime?
  rejectionReason String?
  startedAt       DateTime?
  verifiedAt      DateTime?
  taskItem        TaskItem            @relation(fields: [taskItemId], references: [id], onDelete: Cascade)
  employee        User                @relation(fields: [userId], references: [id])
  submission      TaskItemSubmission?

  @@unique([taskItemId, userId])
  @@index([userId])
}

model ShootWorkspace {
  id          String                 @id @default(uuid())
  name        String
  description String?
  createdById String
  createdAt   DateTime               @default(now())
  updatedAt   DateTime               @updatedAt

  createdBy User                   @relation("UserCreatedShootWorkspaces", fields: [createdById], references: [id])
  members   ShootWorkspaceMember[]
  tasks     ShootTask[]

  @@index([createdById])
}

model ShootWorkspaceMember {
  workspaceId String
  userId      String
  assignedAt  DateTime @default(now())

  workspace ShootWorkspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user      User           @relation("UserShootWorkspaceMembers", fields: [userId], references: [id], onDelete: Cascade)

  @@id([workspaceId, userId])
  @@index([userId])
}

model ShootTask {
  id          String    @id @default(uuid())
  workspaceId String
  title       String
  description String?
  noOfPics    Int       @default(0)
  noOfReels   Int       @default(0)
  date        String?
  arrivalTime String?
  location    String?
  setupType   SetupType?
  createdById String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  workspace ShootWorkspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  createdBy User           @relation("UserCreatedShootTasks", fields: [createdById], references: [id])
  subtasks  ShootSubTask[]

  @@index([workspaceId])
  @@index([createdById])
}

model ShootSubTask {
  id                     String           @id @default(uuid())
  taskId                 String
  dayId                  String?
  title                  String
  description            String?
  type                   ShootSubTaskType
  referenceLinks         String[]
  videoType              VideoType
  setupType              SetupType?        @default(PREMIUM)
  submissionLinks        String[]           @default([])
  unableToSubmitReason   String?
  submittedById          String?
  submittedAt            DateTime?
  status                 ShootSubTaskStatus @default(DRAFT)
  reviewReason           String?
  reviewedById           String?
  reviewedAt             DateTime?
  createdAt              DateTime         @default(now())
  updatedAt              DateTime         @updatedAt

  task ShootTask @relation(fields: [taskId], references: [id], onDelete: Cascade)
  day ProjectMonthlySheetDay? @relation(fields: [dayId], references: [id], onDelete: SetNull)
  submittedBy User? @relation("UserSubmittedShootSubTasks", fields: [submittedById], references: [id])
  reviewedBy  User? @relation("UserReviewedShootSubTasks", fields: [reviewedById], references: [id])

  @@index([taskId])
  @@index([dayId])
  @@index([submittedById])
  @@index([reviewedById])
}

model Department {
  id              String            @id @default(uuid())
  name            String            @unique
  createdAt       DateTime          @default(now())
  users           User[]
  projects        Project[]
  userDepartments UserDepartment[]  @relation("DepartmentUsers")
}

model Project {
  id            String             @id @default(uuid())
  projectName   String
  description   String?
  departmentId  String
  startDate     DateTime
  endDate       DateTime
  renewalDate   DateTime?
  frequency     String?
  clientName    String?
  location      String?
  phone         String?
  fbEmail       String?
  fbPassword    String?
  instaEmail    String?
  instaPassword String?
  projectStartDate DateTime?
  referenceLink String?
  tasteLink     String?
  linkedinEmail String?
  linkedinPassword String?
  youtubeEmail  String?
  youtubePassword String?
  twitterEmail  String?
  twitterPassword String?
  logo          String?
  createdById   String
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt

  department    Department         @relation(fields: [departmentId], references: [id])
  createdBy     User               @relation("CreatedProjects", fields: [createdById], references: [id])
  assignments   ProjectAssignment[]
  monthlySheets ProjectMonthlySheet[]
}

model ProjectAssignment {
  id         String   @id @default(uuid())
  projectId  String
  managerId  String
  assignedAt DateTime @default(now())

  project    Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  manager    User     @relation("ProjectAssignmentManager", fields: [managerId], references: [id])

  @@unique([projectId, managerId])
  @@index([managerId])
  @@index([projectId])
}

model ProjectMonthlySheet {
  id                 String                      @id @default(uuid())
  projectId          String
  month              Int
  year               Int
  totalReels         Int
  totalPosts         Int
  totalReelsUploaded Int
  totalPostsUploaded Int
  moodBoardLink      String
  createdById        String
  createdAt          DateTime                    @default(now())
  updatedAt          DateTime                    @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdBy User @relation("CreatedProjectMonthlySheets", fields: [createdById], references: [id])
  days ProjectMonthlySheetDay[]

  @@unique([projectId, month, year])
  @@index([projectId])
  @@index([createdById])
}

model ProjectMonthlySheetDay {
  id             String             @id @default(uuid())
  sheetId        String
  date           DateTime
  reelType       MediaSource?
  postType       MediaSource?
  videoType      VideoType?
  title          String?
  referenceLinks String[]           @default([])
  submissionLinks String[]          @default([])
  script         String?
  description    String?
  createdAt      DateTime           @default(now())

  sheet ProjectMonthlySheet @relation(fields: [sheetId], references: [id], onDelete: Cascade)
  shootSubTasks ShootSubTask[]

  @@index([sheetId])
  @@unique([sheetId, date])
}

model UserDepartment {
  userId       String
  departmentId String
  assignedAt   DateTime @default(now())

  user         User       @relation("UserDepartments", fields: [userId], references: [id], onDelete: Cascade)
  department   Department @relation("DepartmentUsers", fields: [departmentId], references: [id], onDelete: Cascade)

  @@id([userId, departmentId])
}

model UserManager {
  employeeId String
  managerId  String
  assignedAt DateTime @default(now())

  employee   User @relation("EmployeeManagers", fields: [employeeId], references: [id], onDelete: Cascade)
  manager    User @relation("ManagerEmployees", fields: [managerId], references: [id], onDelete: Cascade)

  @@id([employeeId, managerId])
}

model EmployeeTaskCoverage {
  id         String    @id @default(uuid())
  employeeId String
  managerId  String
  date       DateTime
  taskCount  Int       @default(0)
  checkedAt  DateTime?
  createdAt  DateTime  @default(now())
  employee   User      @relation("EmployeeCoverage", fields: [employeeId], references: [id])
  manager    User      @relation("ManagerCoverage", fields: [managerId], references: [id])

  @@unique([employeeId, date])
  @@index([managerId])
  @@index([date])
}

model CoordinatorAssignment {
  id               String           @id @default(uuid())
  taskId           String
  assignedToId     String
  createdById      String
  assignedBy       String           // Text field - coordinator's name entered manually
  assignedTime     DateTime         @default(now())
  completionDate   DateTime
  reason           String?          // Only for incomplete tasks
  employeeNumber   String
  employeeEmail    String
  status           AssignmentStatus @default(ASSIGNED)
  submittedAt      DateTime?
  completedAt      DateTime?
  rejectedAt       DateTime?
  rejectionReason  String?
  startedAt        DateTime?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  
  task             Task             @relation("CoordinatorAssignments", fields: [taskId], references: [id], onDelete: Cascade)
  assignedTo       User             @relation("AssignedToUser", fields: [assignedToId], references: [id])
  createdBy        User             @relation("CreatedCoordinatorAssignments", fields: [createdById], references: [id])
  followUpMessages CoordinatorFollowUp[]

  @@unique([taskId, assignedToId])
  @@index([createdById])
  @@index([assignedToId])
  @@index([status])
  @@index([assignedTime])
}

model CoordinatorFollowUp {
  id           String                 @id @default(uuid())
  assignmentId String
  senderId     String
  message      String
  messageType  FollowUpMessageType    @default(FOLLOW_UP)
  senderRole   Role
  createdAt    DateTime               @default(now())
  updatedAt    DateTime               @updatedAt

  assignment   CoordinatorAssignment  @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  sender       User                   @relation(fields: [senderId], references: [id])

  @@index([assignmentId])
  @@index([senderId])
}

enum FollowUpMessageType {
  INITIAL
  FOLLOW_UP
  REPLY
}

enum EscalationStatus {
  PENDING
  MANAGER_NOTIFIED
  HR_ESCALATED
  ADMIN_ESCALATED
  FINAL_ESCALATED
  RESOLVED
}

enum Role {
  ADMIN
  HR
  EA
  MANAGER
  EMPLOYEE
  COORDINATOR
}

enum AttendanceStatus {
  PRESENT
  HALF_DAY
  ABSENT
  HOLIDAY
  LEAVE
}

enum SetupType {
  PREMIUM
  VERY_PREMIUM
  PHONE
}

enum TaskStatus {
  DRAFT
  ASSIGNED
  IN_PROGRESS
  SUBMITTED
  VERIFIED
  REJECTED
  COMPLETED
  OVERDUE
  CANCELLED
}

enum AssignmentStatus {
  ASSIGNED
  IN_PROGRESS
  SUBMITTED
  VERIFIED
  REJECTED
  COMPLETED
  PENDING
  UNABLE_TO_SUBMIT
}

enum NotificationLevel {
  INFO
  WARNING
  ESCALATION
  CRITICAL
}

enum NotificationType {
  TASK_ASSIGNED
  TASK_REMINDER
  TASK_SUBMITTED
  TASK_OVERDUE
  MANAGER_REMINDER
  HR_ESCALATION
  ADMIN_ESCALATION
  GENERAL
}

enum LeaveStatus {
  PENDING
  APPROVED
  REJECTED
}

enum LeaveType {
  CASUAL
  SICK
}

enum TaskItemStatus {
  DRAFT
  ASSIGNED
  IN_PROGRESS
  SUBMITTED
  VERIFIED
  REJECTED
  COMPLETED
  PENDING
  UNABLE_TO_SUBMIT
}

enum Priority {
  LOW
  MEDIUM
  HIGH
}

enum MediaSource {
  SHOOT
  AI
}

enum ShootSubTaskType {
  PIC
  REEL
}

enum VideoType {
  HORIZONTAL
  VERTICAL
}

enum ShootSubTaskStatus {
  DRAFT
  SUBMITTED
  APPROVED
  REJECTED
  UNABLE_TO_SUBMIT
}

enum EscalationType {
  NEXT_DAY_MISSING
  FUTURE_4_DAYS_MISSING
}

model SidebarUnread {
  id        String   @id @default(uuid())
  userId    String
  menuId    String
  count     Int      @default(0)
  updatedAt DateTime @updatedAt

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, menuId])
  @@index([userId])
}
