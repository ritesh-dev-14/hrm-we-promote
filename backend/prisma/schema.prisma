generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id          String   @id @default(uuid())
  employeeId  String   @unique

  name        String
  email       String   @unique
  password    String
  role        Role

  department  String?

  createdById String?

  createdBy   User?  @relation("Hierarchy", fields: [createdById], references: [id])
  children    User[] @relation("Hierarchy")

  attendances Attendance[]

  createdAt   DateTime @default(now())
}

enum Role {
  ADMIN
  HR
  MANAGER
  EMPLOYEE
}

model Attendance {
  id         String   @id @default(uuid())
  userId     String
  date       DateTime

  startTime  DateTime?
  endTime    DateTime?

  totalHours Float?      // 👈 already exists (final working hours)
  breakHours Float?      // 👈 NEW (total break time)

  status     AttendanceStatus

  user User @relation(fields: [userId], references: [id])

  breaks Break[]         // 👈 NEW RELATION

  createdAt DateTime @default(now())

  @@unique([userId, date])
}

model Break {
  id            String   @id @default(uuid())
  attendanceId  String

  startTime     DateTime
  endTime       DateTime?

  attendance Attendance @relation(fields: [attendanceId], references: [id])

  createdAt DateTime @default(now())
}

enum AttendanceStatus {
  PRESENT
  HALF_DAY
  ABSENT
}