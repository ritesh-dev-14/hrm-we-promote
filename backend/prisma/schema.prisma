model Task {
  id String @id @default(uuid())

  title       String
  description String?

  instructions  String?
  referenceLink String?

  date DateTime

  location  String?
  setupType SetupType

  // 🔥 WHO CREATED TASK
  createdById String
  createdBy   User   @relation("CreatedTasks", fields: [createdById], references: [id])

  // 🔥 WHO TASK IS FOR
  assignedToRole Role

  // 🔥 TASK TYPE
  isGroupTask Boolean @default(false)

  status TaskStatus @default(DRAFT)

  assignments TaskAssignment[]

  items TaskItem[]

  createdAt DateTime @default(now())

  @@index([createdById])
  @@index([date])
}

enum SetupType {
  PREMIUM
  VERY_PREMIUM
  PHONE
}

enum TaskStatus {
  // PENDING
  // ASSIGNED
  // SUBMITTED
  // VERIFIED

  DRAFT
  ASSIGNED
  IN_PROGRESS
  SUBMITTED
  VERIFIED
  OVERDUE
  CANCELLED
}

