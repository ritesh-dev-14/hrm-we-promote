generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                  String               @id @default(uuid())
  employeeId          String               @unique
  name                String
  email               String               @unique
  password            String
  role                Role
  // department          String?
  departmentId        String?
  department          Department?          @relation(fields: [departmentId], references: [id])
  position            String?
  managerId           String?
  createdById         String?
  createdAt           DateTime             @default(now())
  attendances         Attendance[]
  reviewedLeaves      Leave[]              @relation("LeaveReviewer")
  leaves              Leave[]
  leaveBalance        LeaveBalance[]
  notifications       Notification[]
  createdTasks        Task[]               @relation("CreatedTasks")
  assignments         TaskAssignment[]
  taskItemAssignments TaskItemAssignment[]

  employeeCoverages EmployeeTaskCoverage[] @relation("EmployeeCoverage")

  managerCoverages EmployeeTaskCoverage[] @relation("ManagerCoverage")

  employeeEscalations TaskEscalation[] @relation("EmployeeEscalation")

  managerEscalations TaskEscalation[] @relation("ManagerEscalation")

  createdBy    User?  @relation("Hierarchy", fields: [createdById], references: [id])
  children     User[] @relation("Hierarchy")
  manager      User?  @relation("UserManager", fields: [managerId], references: [id])
  subordinates User[] @relation("UserManager")
}

model Attendance {
  id         String           @id @default(uuid())
  userId     String
  date       DateTime
  startTime  DateTime?
  endTime    DateTime?
  totalHours Float?
  breakHours Float?
  status     AttendanceStatus
  createdAt  DateTime         @default(now())
  user       User             @relation(fields: [userId], references: [id])
  breaks     Break[]

  @@unique([userId, date])
}

model Break {
  id           String     @id @default(uuid())
  attendanceId String
  startTime    DateTime
  endTime      DateTime?
  createdAt    DateTime   @default(now())
  attendance   Attendance @relation(fields: [attendanceId], references: [id])
}

model Task {
  id            String           @id @default(uuid())
  projectName   String
  description   String?
  startDate     DateTime
  endDate       DateTime
  status        TaskStatus       @default(DRAFT)
  createdAt     DateTime         @default(now())
  createdById   String
  createdBy     User             @relation("CreatedTasks", fields: [createdById], references: [id])
  assignments   TaskAssignment[]
  items         TaskItem[]

  progress Int @default(0)

  @@index([createdById])
  @@index([startDate])
  @@index([endDate])
}

model TaskAssignment {
  id String @id @default(uuid())

  taskId String
  userId String

  workDate DateTime


  // 🔥 STATUS
  status AssignmentStatus @default(ASSIGNED)

  // 🔥 PROGRESS %
  progress Int @default(0)

  // 🔥 STARTED TIME
  startedAt DateTime?

  // 🔥 SUBMITTED TIME
  submittedAt DateTime?

  // 🔥 COMPLETED TIME
  completedAt DateTime?

  acceptedAt DateTime?

  verifiedAt DateTime?

  rejectedAt DateTime?

  // 🔥 REJECTION REASON
  rejectionReason String?

  createdAt DateTime @default(now())

  reminderSent Boolean @default(false)

  task Task @relation(fields: [taskId], references: [id])

  employee User @relation(fields: [userId], references: [id])


  submission TaskSubmission?

  @@unique([taskId, userId])
  @@index([workDate])
  @@index([userId, workDate])
  @@index([userId])

  @@index([status])
}

model TaskSubmission {
  id                String         @id @default(uuid())
  assignmentId      String         @unique
  completedCount    Int
  pendingCount      Int
  driveLink         String
  submittedAt       DateTime       @default(now())
  remarks           String?
  verifiedByManager Boolean        @default(false)
  assignment        TaskAssignment @relation(fields: [assignmentId], references: [id])
}

model Notification {
  id        String             @id @default(uuid())
  userId    String
  message   String
  type      NotificationType
  isRead    Boolean            @default(false)
  createdAt DateTime           @default(now())
  entityId  String?
  level     NotificationLevel?
  readAt    DateTime?
  title     String
  user      User               @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([isRead])
}

model Leave {
  id         String      @id @default(uuid())
  userId     String
  startDate  DateTime
  endDate    DateTime
  reason     String
  status     LeaveStatus @default(PENDING)
  reviewedBy String?
  reviewNote String?
  createdAt  DateTime    @default(now())
  days       Int
  type       LeaveType
  reviewer   User?       @relation("LeaveReviewer", fields: [reviewedBy], references: [id])
  user       User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
}

model LeaveBalance {
  id         String   @id @default(uuid())
  userId     String
  casual     Int      @default(14)
  sick       Int      @default(6)
  usedCasual Int      @default(0)
  usedSick   Int      @default(0)
  year       Int
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, year])
}

