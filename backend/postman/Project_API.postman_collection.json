{
  "info": {
    "_postman_id": "project-api",
    "name": "Project API",
    "description": "Collection for testing the Project CRUD endpoints.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "1. Create Project",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{token}}",
            "type": "text"
          },
          {
            "key": "Content-Type",
            "value": "application/json",
            "type": "text"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"projectName\": \"Social Media Campaign Q3\",\n  \"description\": \"Ongoing promotion for third quarter campaign.\",\n  \"departmentId\": \"{{socialMediaDepartmentId}}\",\n  \"startDate\": \"2026-07-01T00:00:00.000Z\",\n  \"endDate\": \"2026-09-30T00:00:00.000Z\",\n  \"renewalDate\": \"2026-10-01T00:00:00.000Z\",\n  \"frequency\": \"monthly\",\n  \"assignTo\": [\"SM-MGR-001\", \"CC-MGR-001\"]\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/projects",
          "host": ["{{baseUrl}}"],
          "path": ["api", "projects"]
        },
        "description": "Create a new project. Allowed roles: ADMIN, HR, EA. Managers are assigned by their employeeId values. Social Media credentials are collected later by the assigned manager."
      },
      "response": []
    },
    {
      "name": "2. Get All Projects",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{token}}",
            "type": "text"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/projects",
          "host": ["{{baseUrl}}"],
          "path": ["api", "projects"]
        },
        "description": "Fetch all projects visible to the current user. Managers see only their assigned projects."
      },
      "response": []
    },
    {
      "name": "3. Get Project By ID",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{token}}",
            "type": "text"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/projects/{{projectId}}",
          "host": ["{{baseUrl}}"],
          "path": ["api", "projects", "{{projectId}}"]
        },
        "description": "Fetch a single project by its ID. Managers may only access assigned projects."
      },
      "response": []
    },
    {
      "name": "4. Update Project (Admin/HR/EA)",
      "request": {
        "method": "PATCH",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{token}}",
            "type": "text"
          },
          {
            "key": "Content-Type",
            "value": "application/json",
            "type": "text"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"description\": \"Updated campaign description.\",\n  \"endDate\": \"2026-10-15T00:00:00.000Z\",\n  \"frequency\": \"monthly\",\n  \"renewalDate\": \"2026-10-16T00:00:00.000Z\",\n  \"assignTo\": [\"SM-MGR-001\"]\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/projects/{{projectId}}",
          "host": ["{{baseUrl}}"],
          "path": ["api", "projects", "{{projectId}}"]
        },
        "description": "Update a project. Allowed roles: ADMIN, HR, EA. Managers may only use the dedicated credential update request."
      },
      "response": []
    },
    {
      "name": "5. Update Social Media Credentials",
      "request": {
        "method": "PATCH",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{token}}",
            "type": "text"
          },
          {
            "key": "Content-Type",
            "value": "application/json",
            "type": "text"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"clientName\": \"Acme Corp\",\n  \"location\": \"New York\",\n  \"phone\": \"1234567890\",\n  \"fbEmail\": \"fb@acme.com\",\n  \"fbPassword\": \"FbSecret123\",\n  \"instaEmail\": \"insta@acme.com\",\n  \"instaPassword\": \"InstaSecret123\",\n  \"projectStartDate\": \"2026-07-01T00:00:00.000Z\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/projects/{{projectId}}",
          "host": ["{{baseUrl}}"],
          "path": ["api", "projects", "{{projectId}}"]
        },
        "description": "Update Social Media credentials only. Assigned managers can set these fields after project assignment."
      },
      "response": []
    },
    {
      "name": "5. Renew Project",
      "request": {
        "method": "PATCH",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{token}}",
            "type": "text"
          },
          {
            "key": "Content-Type",
            "value": "application/json",
            "type": "text"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"renewalDate\": \"2026-10-16T00:00:00.000Z\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/projects/{{projectId}}/renew",
          "host": ["{{baseUrl}}"],
          "path": ["api", "projects", "{{projectId}}", "renew"]
        },
        "description": "Renew an SEO or Social Media project by updating its renewal date."
      },
      "response": []
    },
    {
      "name": "6. Delete Project",
      "request": {
        "method": "DELETE",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{token}}",
            "type": "text"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/projects/{{projectId}}",
          "host": ["{{baseUrl}}"],
          "path": ["api", "projects", "{{projectId}}"]
        },
        "description": "Delete a project. Allowed roles: ADMIN, HR, EA, MANAGER. Managers may delete projects they are assigned to."
      },
      "response": []
    }
  ]
}
