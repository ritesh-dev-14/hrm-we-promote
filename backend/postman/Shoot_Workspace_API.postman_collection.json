        "description": "Delete a shoot workspace. Allowed role: MANAGER."
      },
      "response": []
    },
    {
      "name": "6. Add Shoot Workspace Members",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Authorization", "value": "Bearer {{token}}", "type": "text" },
          { "key": "Content-Type", "value": "application/json", "type": "text" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"employeeIds\": [\"EMP001\", \"EMP002\"]\n}"
        },
        "url": { "raw": "{{baseUrl}}/api/shoot-workspaces/{{workspaceId}}/members", "host": ["{{baseUrl}}"], "path": ["api", "shoot-workspaces", "{{workspaceId}}", "members"] },
        "description": "Add employees to the shoot workspace. Allowed role: MANAGER."
