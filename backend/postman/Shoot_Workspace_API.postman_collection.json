          { "key": "Authorization", "value": "Bearer {{token}}", "type": "text" },
          { "key": "Content-Type", "value": "application/json", "type": "text" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"title\": \"Reel setup\",\n  \"description\": \"Horizontal reel setup with premium props\",\n  \"type\": \"REEL\",\n  \"referenceLinks\": [\"https://example.com/reel1\"],\n  \"videoType\": \"HORIZONTAL\"\n}"
