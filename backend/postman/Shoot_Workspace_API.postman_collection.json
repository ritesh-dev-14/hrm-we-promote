        "url": { "raw": "{{baseUrl}}/api/shoot-workspaces/{{workspaceId}}/tasks/{{taskId}}", "host": ["{{baseUrl}}"], "path": ["api", "shoot-workspaces", "{{workspaceId}}", "tasks", "{{taskId}}"] },
        "description": "Update a shoot task. Allowed role: MANAGER."
      },
      "response": []
