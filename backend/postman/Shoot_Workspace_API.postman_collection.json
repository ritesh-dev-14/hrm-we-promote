          { "key": "Authorization", "value": "Bearer {{token}}", "type": "text" },
          { "key": "Content-Type", "value": "application/json", "type": "text" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"brandName\": \"Shoot Workspace Alpha Updated\",\n  \"description\": \"Updated workspace description\"\n}"
        },
        "url": { "raw": "{{baseUrl}}/api/shoot-workspaces/{{workspaceId}}", "host": ["{{baseUrl}}"], "path": ["api", "shoot-workspaces", "{{workspaceId}}"] },
        "description": "Update workspace metadata. Allowed role: MANAGER."
