        "url": { "raw": "{{baseUrl}}/api/shoot-workspaces/{{workspaceId}}/tasks/{{taskId}}/subtasks/{{subtaskId}}/review", "host": ["{{baseUrl}}"], "path": ["api", "shoot-workspaces", "{{workspaceId}}", "tasks", "{{taskId}}", "subtasks", "{{subtaskId}}", "review"] },
        "description": "Review a submitted shoot subtask. Allowed role: MANAGER. Use status APPROVED or REJECTED, and include reason for rejected submissions."
      },
      "response": []
