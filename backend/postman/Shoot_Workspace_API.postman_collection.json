{
  "info": {
    "_postman_id": "shoot-workspace-api",
    "name": "Shoot Workspace API",
    "description": "API collection for Shoot Workspace management, tasks, and subtasks.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "1. Create Shoot Workspace",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Authorization", "value": "Bearer {{token}}", "type": "text" },
          { "key": "Content-Type", "value": "application/json", "type": "text" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"brandName\": \"Shoot Workspace Alpha\",\n  \"description\": \"Workspace for shoot department tasks\"\n}"
        },
        "url": { "raw": "{{baseUrl}}/api/shoot-workspaces", "host": ["{{baseUrl}}"], "path": ["api", "shoot-workspaces"] },
        "description": "Create a new shoot workspace. Allowed role: MANAGER."
      },
      "response": []
    },
    {
      "name": "2. Get Shoot Workspaces",
      "request": {
        "method": "GET",
        "header": [ { "key": "Authorization", "value": "Bearer {{token}}", "type": "text" } ],
        "url": { "raw": "{{baseUrl}}/api/shoot-workspaces", "host": ["{{baseUrl}}"], "path": ["api", "shoot-workspaces"] },
        "description": "List shoot workspaces visible to the authenticated user."
      },
      "response": []
    },
    {
