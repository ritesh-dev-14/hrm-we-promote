          { "key": "Content-Type", "value": "application/json", "type": "text" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"title\": \"Shoot Task 1\",\n  \"description\": \"Create campaign shoot plan\",\n  \"noOfPics\": 10,\n  \"noOfReels\": 3,\n  \"date\": \"2026-06-30\",\n  \"arrivalTime\": \"10:00\",\n  \"location\": \"https://maps.google.com/?q=studio\",\n  \"setupType\": \"PREMIUM\"\n}"
        },
        "url": { "raw": "{{baseUrl}}/api/shoot-workspaces/{{workspaceId}}/tasks", "host": ["{{baseUrl}}"], "path": ["api", "shoot-workspaces", "{{workspaceId}}", "tasks"] },
        "description": "Create a shoot task inside the workspace. Allowed role: MANAGER."
      },
      "response": []
    },
