      "name": "15. Submit Shoot Subtask",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Authorization", "value": "Bearer {{token}}", "type": "text" },
          { "key": "Content-Type", "value": "application/json", "type": "text" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"submissionLinks\": [\"https://docs.google.com/spreadsheets/d/example\" ]\n}"
        },
        "url": { "raw": "{{baseUrl}}/api/shoot-workspaces/{{workspaceId}}/tasks/{{taskId}}/subtasks/{{subtaskId}}/submit", "host": ["{{baseUrl}}"], "path": ["api", "shoot-workspaces", "{{workspaceId}}", "tasks", "{{taskId}}", "subtasks", "{{subtaskId}}", "submit"] },
        "description": "Submit a shoot subtask with a reference link. Employees may also submit only unableToSubmitReason if they cannot complete it."
      },
      "response": []
    },
    {
      "name": "16. Review Shoot Subtask",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Authorization", "value": "Bearer {{token}}", "type": "text" },
          { "key": "Content-Type", "value": "application/json", "type": "text" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"status\": \"APPROVED\"\n}"
